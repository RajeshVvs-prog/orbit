# NASA_API_KEY: Get your key at https://api.nasa.gov/
# You can use DEMO_KEY for testing, but it has rate limits
NASA_API_KEY="DEMO_KEY"

# GROQ_API_KEY: Required for Groq AI API calls.
# Get your API key from https://console.groq.com/keys
# This key should ONLY be set on the server (backend) - never expose it in frontend code
GROQ_API_KEY="your_groq_api_key_here"

# PORT: The port the server will run on (optional, defaults to 3000)
PORT=3000
